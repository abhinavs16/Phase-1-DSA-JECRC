#include <iostream>
using namespace std;
// Copy constructor

class Student
{
  public:
  string name;
  int age;
  int roll_no;


  Student(string name, int age, int roll_no)
  {
    this->name= name;
    this->age=age;
    this->roll_no=roll_no;
  }
  
  Student(Student &a)
  {
    name = a.name;
    age = a.age;
    roll_no = a.roll_no;
  }
};
