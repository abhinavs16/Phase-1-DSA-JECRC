/*****Encapsulation and Abstraction*****/
#include <iostream>
using namespace std;
// 4-Pillars
// Encapsulation/Abstraction
class Student
{
  private:
  // Properties
  string name;
  int age;
  int roll_no;

  public:
  void setter(string n, int a, int r)
  {
    name = n;
    age = a;
    roll_no = r;
  }

  int getter ()
  {
    return age;

  }
};


int main()
{
  Student obj;
  obj.setter("alex", 24, 01);
  cout<<obj.getter();


    return 0;
}

