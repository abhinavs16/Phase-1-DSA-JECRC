#include <iostream>
using namespace std;
// Inheritance

class Human
{
    // Properties
    protected:
    string name;

};

class person : public Human
{
    protected:
    int age;
};

class Student :public person
{
    // int age;
    int roll_no;

    public:
    Student(string n, int a, int r)
    {
        name = n;
        roll_no = a;
        age = r;

    }

    void display()
    {
        cout<<name<<" "<<age<<" "<<roll_no<<endl;
    }

};
int main() 
{
    Student obj("Abhi",21,13);
    obj.display();


    return 0;
}
